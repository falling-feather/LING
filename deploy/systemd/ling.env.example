# 复制为 /etc/ling/ling.env，并设置 600 权限：
#   sudo install -m 600 ling.env.example /etc/ling/ling.env
#   sudo chown ling:ling /etc/ling/ling.env

# GitHub PAT，需要对记忆仓库有 repo 权限
GITHUB_TOKEN=ghp_replace_me

# 可选：让 git 在间歇性 schannel 失败时切到 OpenSSL（Linux 服务器一般不需要）
# LING_GIT_SSL_BACKEND=openssl
# LING_GIT_HTTP_VERSION=HTTP/1.1
